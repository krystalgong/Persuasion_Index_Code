# Copy this file to .env and edit values for your local machine.
# Never commit .env with real API keys.

# Required only for lexicons/LLM_expansion/generator_runner.py
OPENAI_API_KEY=

# Optional: set if your institution or proxy uses a custom OpenAI endpoint.
# Leave blank for the default OpenAI API endpoint.
OPENAI_BASE_URL=

# Optional: default model used by generator_runner.py when --model is omitted.
OPENAI_MODEL=gpt-5.4-mini

# Optional OpenAI account scoping.
OPENAI_ORGANIZATION=
OPENAI_PROJECT=

# Optional Persuasion Index paths/settings.
# Leave blank for normal repo use. Relative paths resolve from the repo root.
PI_HELPER_DIR=
PI_LEXICON_FILE=
PI_DISABLE_SPACY=0
